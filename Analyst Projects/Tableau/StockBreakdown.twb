        <zone flipboard-zone-id='5' forceUpdate='true' h='7743' id='6' story-point-id='1' type-v2='text' w='80925' x='6319' y='5531'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Through these charts it can be noted that information technology had the highest daily returns and dominated in trade volume, while real estate and consumer staples were negative over the same 2022 - 2025 period. </run>
          </formatted-text>
        </zone>
