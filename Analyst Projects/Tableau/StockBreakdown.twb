        <zone flipboard-zone-id='5' forceUpdate='true' h='8588' id='6' story-point-id='1' type-v2='text' w='70720' x='15600' y='4824'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='12'>Stocks in the top left quadrant show low risk and high reward and bottom right show high risk and low reward. More stable stocks are clustered around the zero to ten price range while more volatile ones sit further down. </run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{3F1273EE-BCD5-4F33-8B4F-DACEF52ABD92}' />
