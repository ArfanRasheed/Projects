            <zone fixed-size='104' h='7636' id='4' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98720' x='640' y='4728' />
            <zone h='86666' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98720' x='640' y='12364'>
              <flipboard active-id='1' nav-type='dot' show-nav-arrows='true'>
